DATABASE_URL=postgres://user:pass@localhost:5432/wardi_cafe
PORT=3000
NODE_ENV=development

# Comma-separated allowed origins, or omit to reflect the request Origin (typical for local Vite).
# CORS_ORIGIN=http://localhost:5173

# Solo en producción detrás de reverse proxy (Railway, etc.). Sin proxy local: no definir o 0.
# TRUST_PROXY=1

# Límite global de peticiones / minuto por IP (además del rate limit de login).
# API_RL_MAX_PER_MINUTE=400

# Tipo de cambio USD (BCCR REST SDDE 2025+) — referencia en Gastos / Inventario
# Base API (sin path .asmx): GET …/indicadoresEconomicos/{codigo}/series
# BCCR_API_URL=https://apim.bccr.fi.cr/SDDE/api/Bccr.Ge.SDDE.Publico.Indicadores.API
# Bearer token (suscripción APIM BCCR)
# BCCR_TOKEN=
# Hosts permitidos (opcional; por defecto: apim.bccr.fi.cr)
# BCCR_ALLOWED_HOSTS=apim.bccr.fi.cr
# BCCR_INDICADOR_COMPRA=317
# BCCR_INDICADOR_VENTA=318

# URL pública del PWA (enlaces en correos, ej. recuperación de contraseña).
# FRONTEND_URL=http://localhost:5173

# Resend — envío de correo (recuperación de contraseña). MAIL_FROM debe ser un remitente verificado en Resend.
# RESEND_API_KEY=
# MAIL_FROM=noreply@tudominio.com

# Logo en correos: adjunto inline (CID). Por defecto se busca pwa/public/images/logo.(jpeg|jpg|png) desde la API.
# EMAIL_LOGO_PATH=C:\\ruta\\absoluta\\logo.png

# Límites opcionales recuperación de contraseña (por IP y hora)
# PASSWORD_RESET_REQUEST_MAX_HOUR=8
# PASSWORD_RESET_CONSUME_MAX_PER_HOUR=30

# --- Checklist producción (Railway / VPS) ---
# NODE_ENV=production
# CORS_ORIGIN=https://tu-dominio-pwa.com
# TRUST_PROXY=1
# FRONTEND_URL=https://tu-dominio-pwa.com
# DATABASE_URL=postgres://... (credenciales solo en el proveedor, no en git)
# Revisar backups PostgreSQL, monitoreo de errores y secret rotation (RESEND, BCCR, etc.).
# RLS multitenant: contraseña del rol wardi_app (solo para npm run db:setup-role; no commitear).
# PG_APP_PASSWORD=cambiar_por_contraseña_de_al_menos_12_caracteres
# Pasos: 1) DATABASE_URL con postgres → npm run db:setup-role
#        2) npm run db:migrate
#        3) DATABASE_URL=postgres://wardi_app:LA_MISMA_CONTRASEÑA@host:5432/wardi_cafe
# TENANT_RLS_REQUEST_SCOPE=0   # solo desactivar set_config por request (depuración)

# Licencias por cliente (cron 23:59, vencimiento en login y panel admin)
# LICENSE_TIMEZONE=America/Costa_Rica
# LICENSE_CRON_SCHEDULE=59 23 * * *
# LICENSE_CRON_ENABLED=1
